    "    \"\"\"Find attached Kaggle assets under .../triagegeist_kaggle_assets/outputs/.\"\"\"\n",
    "    candidates: list[Path] = []\n",
    "\n",
    "    explicit = [\n",
    "        Path(REPO_ROOT) / \"triagegeist_kaggle_assets\" / \"outputs\",\n",
    "        Path(\"/kaggle/input/triagegeist-submission-assets/triagegeist_kaggle_assets/outputs\"),\n",
    "    ]\n",
    "    if not ON_KAGGLE:\n",
    "        explicit = [\n",
    "            Path(\"../outputs\"),\n",
    "            Path(\"./outputs\"),\n",
    "            Path(REPO_ROOT) / \"outputs\",\n",
    "            *explicit,\n",
    "        ]\n",
    "\n",
    "    for p in explicit:\n",
    "        if _is_valid_outputs_root(p) and not _is_excluded_asset_source(p):\n",
    "            candidates.append(p.resolve())\n",
    "\n",
    "    kaggle_input = Path(\"/kaggle/input\")\n",
    "    if kaggle_input.is_dir():\n",
    "        for p in kaggle_input.glob(\"*/triagegeist_kaggle_assets/outputs\"):\n",
    "            if _is_valid_outputs_root(p) and not _is_excluded_asset_source(p):\n",
    "                candidates.append(p.resolve())\n",
    "        for p in kaggle_input.rglob(\"outputs\"):\n",
    "            if _is_valid_outputs_root(p) and not _is_excluded_asset_source(p):\n",
    "                candidates.append(p.resolve())\n",
    "\n",
    "    if not candidates:\n",
    "        return None\n",
    "\n",
    "    unique = list(dict.fromkeys(candidates))\n",
    "    unique.sort(key=_score_outputs_root, reverse=True)\n",
    "    return unique[0]\n",
    "\n",
    "\n",
    "def copy_kaggle_assets(src_outputs: Path, dst_outputs: Path) -> dict:\n",
    "    \"\"\"Copy aggregate PNG/CSV assets only (no raw data). Idempotent on re-run.\"\"\"\n",
    "    stats = {\"figures\": 0, \"tables\": 0}\n",
    "    src_outputs = Path(src_outputs).resolve()\n",
    "    dst_outputs = Path(dst_outputs).resolve()\n",
    "\n",
    "    if src_outputs == dst_outputs:\n",
    "        print(\n",
    "            f\"[asset copy] Source and destination are the same ({src_outputs}); skipping copy.\"\n",
    "        )\n",
    "        return stats\n",
    "\n",
    "    fig_dst = dst_outputs / \"figures\"\n",
    "    tbl_dst = dst_outputs / \"tables\"\n",
    "    fig_dst.mkdir(parents=True, exist_ok=True)\n",
    "    tbl_dst.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "    src_fig = src_outputs / \"figures\"\n",
    "    if src_fig.is_dir():\n",
    "        for f in src_fig.glob(\"*.png\"):\n",
    "            dst_file = fig_dst / f.name\n",
    "            if f.resolve() == dst_file.resolve():\n",
    "                continue\n",
    "            shutil.copy2(f, dst_file)\n",
    "            stats[\"figures\"] += 1\n",
    "\n",
    "    src_tbl = src_outputs / \"tables\"\n",
    "    if src_tbl.is_dir():\n",
    "        for f in src_tbl.glob(\"*.csv\"):\n",
    "            dst_file = tbl_dst / f.name\n",
    "            if f.resolve() == dst_file.resolve():\n",
    "                continue\n",
    "            shutil.copy2(f, dst_file)\n",
    "            stats[\"tables\"] += 1\n",
    "\n",
    "    return stats\n",
    "\n",
    "\n",
    "ASSETS_OUTPUTS_SRC = find_assets_outputs_root()\n",
    "copy_stats = {\"figures\": 0, \"tables\": 0}\n",
    "\n",
    "if ON_KAGGLE:\n",
    "    OUTPUTS_DIR = Path(\"/kaggle/working/outputs\")\n",
    "    if ASSETS_OUTPUTS_SRC is not None:\n",
    "        copy_stats = copy_kaggle_assets(ASSETS_OUTPUTS_SRC, OUTPUTS_DIR)\n",
    "        print(\n",
