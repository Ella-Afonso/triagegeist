    "\n",
    "\n",
    "def prettify_df(df, cols=None):\n",
    "    out = df.copy()\n",
    "    if cols is None:\n",
    "        cols = [c for c in out.columns if c in (\n",
    "            \"target\", \"model_variant\", \"model\", \"label_only_model\", \"triage_time_model\"\n",
    "        )]\n",
    "    for col in cols:\n",
    "        if col in out.columns:\n",
