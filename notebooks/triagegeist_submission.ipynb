    "\n",
    "def find_competition_data_dir():\n",
    "    candidates = []\n",
    "\n",
    "    try:\n",
    "        candidates.append(Path(config.DATA_DIR))\n",
    "    except Exception:\n",
    "        pass\n",
    "\n",
    "    candidates.extend([\n",
    "        Path(\"/kaggle/input/triagegeist\"),\n",
    "        Path(\"/kaggle/input\"),\n",
    "    ])\n",
    "\n",
    "    kaggle_input = Path(\"/kaggle/input\")\n",
    "    if kaggle_input.exists():\n",
    "        candidates.extend([p for p in kaggle_input.glob(\"*\") if p.is_dir()])\n",
    "        candidates.extend([p for p in kaggle_input.rglob(\"*\") if p.is_dir()])\n",
    "\n",
    "    seen = set()\n",
    "    for d in candidates:\n",
    "        d = Path(d)\n",
    "        key = str(d.resolve()) if d.exists() else str(d)\n",
    "        if key in seen:\n",
    "            continue\n",
    "        seen.add(key)\n",
    "\n",
    "        if d.exists() and all((d / f).exists() for f in REQUIRED_COMPETITION_FILES):\n",
