    "        score += 2\n",
    "    if (p / \"tables\" / \"table_final_summary_metrics.csv\").is_file():\n",
    "        score += 2\n",
    "    if (p / \"figures\").is_dir():\n",
    "        score += 1\n",
    "    if (p / \"tables\").is_dir():\n",
    "        score += 1\n",
    "    return score\n",
    "\n",
    "\n",
    "KAGGLE_DST_OUTPUTS = Path(\"/kaggle/working/outputs\")\n",
    "\n",
    "\n",
    "def _is_excluded_asset_source(p: Path) -> bool:\n",
    "    \"\"\"On Kaggle, never treat /kaggle/working/outputs as the asset source.\"\"\"\n",
    "    if not ON_KAGGLE:\n",
    "        return False\n",
    "    try:\n",
    "        resolved = p.resolve()\n",
    "    except OSError:\n",
    "        return True\n",
    "    kaggle_working = Path(\"/kaggle/working\").resolve()\n",
