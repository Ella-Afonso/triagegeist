    "        ax.plot(rec, prec, lw=1.8, color=col,\n",
    "                label=f\"{_legend_names[name]} (AP={ap:.3f})\")\n",
    "    ax.axhline(base, ls=\"--\", color=\"#7f8c8d\", lw=1.3,\n",
