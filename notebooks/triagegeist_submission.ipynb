    "\n",
    "# --- Section 9b: load, link, filter (aggregate prints only) ---\n",
    "if MIMIC_AVAILABLE:\n",
    "    from scipy.sparse import hstack as sparse_hstack, csr_matrix\n",
    "    from sklearn.feature_extraction.text import TfidfVectorizer\n",
