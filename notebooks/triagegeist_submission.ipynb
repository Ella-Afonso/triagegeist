    "def _is_valid_outputs_root(p: Path) -> bool:\n",
    "    return p.is_dir() and ((p / \"figures\").is_dir() or (p / \"tables\").is_dir())\n",
    "\n",
    "\n",
    "def _score_outputs_root(p: Path) -> int:\n",
