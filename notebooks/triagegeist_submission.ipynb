    "    print(f\"  (c) chief complaint (rfv1_code)   : {ap_c:.3f}\")\n",
    "    print(f\"  full feature set (reference)      : {ap_full:.3f}\")\n",
    "    broad = sum(x > base_adm + 0.05 for x in (ap_a, ap_b, ap_c)) >= 2\n",
